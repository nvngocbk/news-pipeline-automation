# Copy this file to .env and fill in real values. .env is gitignored.
# Shell / cron env vars always override these — file is just a fallback.

# Required for AI-rewritten summary_vi. Absent → pipeline falls back to RSS
# description for every story (current pre-AI behavior).
CHIASEGPU_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides — leave commented to use defaults from ai_summarize.py.
# CHIASEGPU_BASE_URL=https://llm.chiasegpu.vn/v1
# CHIASEGPU_MODEL=gpt-5.5
# AI_SUMMARY_ENABLED=1
# AI_SUMMARY_TIMEOUT=30
# AI_SUMMARY_MAX_BODY_CHARS=8000
